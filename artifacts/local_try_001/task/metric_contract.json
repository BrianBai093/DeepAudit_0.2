{
  "required_metrics": [
    "accuracy"
  ],
  "parsers": [
    {
      "name": "acc_percent",
      "regex": "accuracy[^0-9]*(\\d+(?:\\.\\d+)?)%",
      "metric_name": "accuracy",
      "transform": "float"
    },
    {
      "name": "acc_decimal",
      "regex": "accuracy[^0-9]*(0\\.\\d+|1\\.0+)",
      "metric_name": "accuracy",
      "transform": "float"
    }
  ],
  "normalization": {
    "accuracy": {
      "percent_to_decimal": true,
      "clip": [
        0,
        1
      ]
    }
  },
  "reason_codes": []
}