+import os
+
+import numpy as np
+
+
+class NearestNeighbor:
+    def __init__(self, train_features, train_labels, sequence_length):
+        self.train_features = np.asarray(train_features, dtype=np.float32)
+        self.train_labels = np.asarray(train_labels, dtype=np.int64)
+        self.sequence_length = int(sequence_length)
+        self.accuracy = 0.0
+
+    def predict(self, test_features, test_labels, result_path):
+        test_features = np.asarray(test_features, dtype=np.float32)
+        test_labels = np.asarray(test_labels, dtype=np.int64)
+
+        if not os.path.exists(result_path):
+            os.makedirs(result_path, exist_ok=True)
+
+        num_test = test_features.shape[0]
+
+        for index in range(num_test):
+            x = test_features[index]
+            dists = np.linalg.norm(self.train_features - x, axis=1)
+            nn_index = int(np.argmin(dists))
+
+            pred_label = int(self.train_labels[nn_index])
+            actual_label = int(test_labels[index])
+
+            print(
+                "Test [{}] Actual Class: {}, Predicted Class : {}".format(
+                    index, actual_label, pred_label
+                )
+            )
+
+            self.save_labels(
+                predictions=pred_label,
+                actual=actual_label,
+                result_path=result_path,
+                step=index,
+                phase="testing",
+            )
+
+            if pred_label == actual_label:
+                self.accuracy += 1.0 / num_test
+
+        print("accuracy {:.4f}".format(self.accuracy))
+
+    @staticmethod
+    def save_labels(predictions, actual, result_path, step, phase):
+        if not os.path.exists(result_path):
+            os.makedirs(result_path, exist_ok=True)
+
+        labels = np.array([predictions, actual])
+
+        np.save(
+            file=os.path.join(
+                result_path, "{}-nearest_neighbor-{}.npy".format(phase, step)
+            ),
+            arr=labels,
+        )
+
